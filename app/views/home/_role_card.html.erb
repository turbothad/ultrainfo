<%= link_to href, class: "group flex flex-col justify-between rounded-2xl border border-ink/10 bg-card p-6 no-underline transition hover:border-ink/30" do %>
  <div>
    <% if local_assigns[:eyebrow] %>
      <div class="font-mono text-[10px] uppercase tracking-[0.13em] text-stone-light"><%= eyebrow %></div>
    <% end %>
    <h3 class="mt-2 text-[21px] font-extrabold leading-tight tracking-[-0.015em] text-ink"><%= label %></h3>
    <p class="mt-3 text-sm leading-relaxed text-stone"><%= blurb %></p>
  </div>
  <div class="mt-6 flex items-center justify-between border-t border-ink/10 pt-4">
    <span class="font-mono text-[11px] uppercase tracking-[0.1em] text-stone"><%= local_assigns[:stat] %></span>
    <span class="inline-flex items-center gap-1.5 font-mono text-xs font-bold uppercase tracking-[0.12em] text-flame">
      Open
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="transition group-hover:translate-x-1">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
<% end %>
