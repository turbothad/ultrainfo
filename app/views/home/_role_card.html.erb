<%= link_to href, class: "group flex flex-col justify-between rounded-2xl border border-ink/10 bg-card p-6 no-underline transition hover:border-ink/30" do %>
  <div>
    <h3 class="text-2xl font-extrabold tracking-tight text-ink"><%= label %></h3>
    <p class="mt-3 text-sm leading-relaxed text-stone"><%= blurb %></p>
  </div>
  <span class="mt-6 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.12em] text-flame">
    Open
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="transition group-hover:translate-x-1">
      <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
<% end %>
