<section class="mx-auto max-w-[1240px] px-6 py-16 sm:px-10 sm:py-24">
  <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-flame"><%= eyebrow %></p>
  <h1 class="mb-4 max-w-3xl text-balance text-4xl font-black uppercase leading-[0.95] tracking-tight sm:text-5xl"><%= title %></h1>
  <p class="mb-10 max-w-2xl text-lg font-medium leading-relaxed text-stone"><%= intro %></p>

  <div class="rounded-2xl border border-ink/10 bg-card p-6 sm:p-8">
    <div class="mb-4 font-mono text-[11px] uppercase tracking-[0.14em] text-stone">What you'll find here</div>
    <ul class="grid gap-3 sm:grid-cols-2">
      <% items.each do |item| %>
        <li class="flex items-start gap-3 text-sm font-medium text-ink">
          <span class="mt-0.5 font-bold text-pine">›</span><%= item %>
        </li>
      <% end %>
    </ul>
    <p class="mt-6 font-mono text-xs text-stone-light">Scaffolding in progress — content lands as we build out the event data.</p>
  </div>

  <div class="mt-8 flex flex-wrap items-center gap-4 text-sm font-semibold">
    <span class="text-stone">Switch role:</span>
    <%= link_to "Run it", runner_path, class: "no-underline text-ink hover:text-flame" %>
    <%= link_to "Crew", crew_path, class: "no-underline text-ink hover:text-flame" %>
    <%= link_to "Follow", follow_path, class: "no-underline text-ink hover:text-flame" %>
  </div>
</section>
