<% if @race %>
  <!-- ===================== HERO ===================== -->
  <section class="mx-auto grid max-w-[1240px] items-center gap-10 px-6 pb-14 pt-14 sm:px-10 lg:grid-cols-[1.04fr_0.96fr] lg:gap-[54px] lg:pb-[70px] lg:pt-[58px]">
    <div>
      <p class="mb-[22px] font-mono text-xs font-medium uppercase tracking-[0.2em] text-flame">
        The 100-mile info project<%= " · #{@race.name}" if @race.name %>
      </p>
      <%# [PLACEHOLDER copy — refine headline wording] %>
      <h1 class="mb-[22px] text-[clamp(2.6rem,5.6vw,5.1rem)] font-black uppercase leading-[0.92] tracking-[-0.03em]">
        Bighorn 100,<br>start to finish,<br>in one place.
      </h1>
      <p class="mb-[30px] max-w-[480px] text-lg font-medium leading-[1.55] text-[#534d40]">
        The schedule, the course, every aid station, and exactly where your crew can go —
        pulled out of a dozen old race-site links. Free and open source.
      </p>

      <div class="mb-[42px] flex flex-wrap gap-3">
        <%= link_to crew_race_path(@race), class: "inline-flex items-center gap-2 rounded-full bg-flame px-[26px] py-[15px] text-[15px] font-bold text-white no-underline transition hover:bg-flame-dark" do %>
          Crew the race
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <% end %>
        <%= link_to "Run it", runner_race_path(@race), class: "rounded-full border border-ink/25 px-[26px] py-[15px] text-[15px] font-bold text-ink no-underline transition hover:border-ink hover:bg-ink/5" %>
        <%= link_to "Follow", follow_race_path(@race), class: "rounded-full border border-ink/25 px-[26px] py-[15px] text-[15px] font-bold text-ink no-underline transition hover:border-ink hover:bg-ink/5" %>
      </div>

      <dl class="flex flex-wrap gap-x-[38px] gap-y-4 border-t border-ink/10 pt-6 font-mono">
        <% [["Miles", @race.distance_mi&.to_i],
            ["Ft of vert", @race.elevation_gain_ft && number_with_delimiter(@race.elevation_gain_ft)],
            ["Aid stations", @race.aid_stations.size]].each do |label, value| %>
          <div>
            <dd class="text-[30px] font-bold leading-none tracking-[-0.02em]"><%= value.presence || "—" %></dd>
            <dt class="mt-[3px] text-[11px] uppercase tracking-[0.14em] text-stone"><%= label %></dt>
          </div>
        <% end %>
      </dl>
    </div>

    <%= render "races/hero_map", race: @race %>
  </section>

  <!-- trust strip -->
  <div class="mx-auto hidden max-w-[1240px] flex-wrap items-center gap-x-[34px] gap-y-3 border-t border-ink/10 px-6 pt-6 font-mono text-[11px] uppercase tracking-[0.16em] text-stone-light sm:flex sm:px-10">
    <span class="text-stone">Plotting the course with</span>
    <span class="font-bold text-[#534d40]">OpenStreetMap</span>
    <span class="font-bold text-[#534d40]">Leaflet</span>
    <span class="font-bold text-[#534d40]">GPX / GeoJSON</span>
  </div>

  <!-- choose your role -->
  <section class="mx-auto max-w-[1240px] px-6 pb-4 pt-14 sm:px-10">
    <h2 class="mb-6 font-mono text-xs uppercase tracking-[0.2em] text-stone">Choose your role</h2>
    <div class="grid gap-4 md:grid-cols-3">
      <%= render "home/role_card", href: runner_race_path(@race), eyebrow: "For runners", label: "Run it",
            blurb: "Schedule, cutoffs, the registration link, the course, and what to expect.",
            stat: (@race.cutoff_hours ? "#{@race.cutoff_hours.to_i} h cutoff" : "course + cutoffs") %>
      <%= render "home/role_card", href: crew_race_path(@race), eyebrow: "For crews & pacers", label: "Crew or pace",
            blurb: "The crew-access map, which stations allow crew, parking & drop bags.",
            stat: "#{@race.aid_stations.crew.size} crew stops" %>
      <%= render "home/role_card", href: follow_race_path(@race), eyebrow: "For spectators", label: "Follow along",
            blurb: "Live tracking, the best spots to watch from, and the finish.",
            stat: "#{@race.aid_stations.crew.size} viewpoints" %>
    </div>
  </section>

  <section class="mx-auto max-w-[1240px] px-6 pb-20 pt-12 sm:px-10">
    <p class="text-sm text-stone">
      Built by one runner. No ads, no accounts, no upsell — just the info.
      <%= link_to "Open the #{@race.name} overview →", race_path(@race), class: "font-semibold text-ink underline-offset-2 hover:text-flame" %>
      · <a href="#about" class="font-semibold text-ink underline-offset-2 hover:text-flame">why this exists</a>
    </p>
  </section>
<% else %>
  <section class="mx-auto max-w-[1240px] px-6 py-24 text-stone sm:px-10">No races loaded yet.</section>
<% end %>
