<section class="mx-auto max-w-[1240px] px-6 pb-10 pt-16 sm:px-10 sm:pt-24">
  <p class="mb-5 font-mono text-xs uppercase tracking-[0.2em] text-flame">
    The 100-mile info project<%= " · #{@race.name} · #{@race.start_date.strftime('%B %-d, %Y')}" if @race&.start_date %>
  </p>
  <h1 class="mb-5 max-w-3xl text-balance text-4xl font-black uppercase leading-[0.95] tracking-tight sm:text-6xl">
    <%= @race ? "One place for everything #{@race.name}." : "Ultra event info, made usable." %>
  </h1>
  <p class="max-w-2xl text-lg font-medium leading-relaxed text-stone">
    The schedule, the course map, aid stations, crew access, and where to follow along —
    pulled out of a dozen old race-site links and laid out plainly. Free and open source.
  </p>
</section>

<% if @race %>
  <section class="mx-auto max-w-[1240px] px-6 pb-16 sm:px-10">
    <h2 class="mb-6 font-mono text-xs uppercase tracking-[0.2em] text-stone">I'm here to…</h2>
    <div class="grid gap-4 md:grid-cols-3">
      <%= render "home/role_card", href: runner_race_path(@race), label: "Run it",
            blurb: "Schedule, cutoffs, the registration link, the course, and what to expect out there." %>
      <%= render "home/role_card", href: crew_race_path(@race), label: "Crew or pace",
            blurb: "Which aid stations allow crew, the crew-access map, parking & drop bags." %>
      <%= render "home/role_card", href: follow_race_path(@race), label: "Follow along",
            blurb: "Live tracking, the best spots to watch from, and the finish." %>
    </div>
    <p class="mt-8 text-sm text-stone">
      Or just <%= link_to "open the #{@race.name} overview →", race_path(@race),
        class: "font-semibold text-ink underline-offset-2 hover:text-flame" %>.
    </p>
  </section>
<% else %>
  <section class="mx-auto max-w-[1240px] px-6 pb-16 text-stone sm:px-10">No races loaded yet.</section>
<% end %>

<section class="mx-auto max-w-[1240px] px-6 pb-20 sm:px-10">
  <p class="text-sm text-stone">
    Built by one runner. No ads, no accounts, no upsell — just the info.
    <a href="#about" class="font-semibold text-ink underline-offset-2 hover:text-flame">Why this exists →</a>
  </p>
</section>
