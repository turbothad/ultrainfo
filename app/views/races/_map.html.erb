<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<% end %>
<% drive = local_assigns[:drive] && race.crew_route.present? %>
<div data-controller="map" data-map-url-value="<%= map_race_path(race, format: :json) %>"
     data-map-drive-value="<%= drive %>"
     class="overflow-hidden rounded-2xl border border-ink/10">
  <div data-map-target="canvas" class="h-[460px] w-full bg-paper"></div>
  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-ink/10 bg-card px-4 py-3 text-sm">
    <span class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-full bg-pine"></span>Crew-accessible</span>
    <span class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-full bg-stone-light"></span>No crew</span>
    <% if drive %>
      <span class="flex items-center gap-2"><span class="inline-block h-0 w-6 border-t-2 border-dashed border-ink"></span>Crew drive</span>
    <% end %>
    <label class="ml-auto flex cursor-pointer items-center gap-2 font-medium">
      <input type="checkbox" checked data-action="map#toggleOther" class="accent-flame"> Non-crew
    </label>
    <% if drive %>
      <label class="flex cursor-pointer items-center gap-2 font-medium">
        <input type="checkbox" checked data-action="map#toggleDrive" class="accent-flame"> Crew drive
      </label>
    <% end %>
  </div>
</div>
