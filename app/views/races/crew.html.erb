<%= render "races/race_header", race: @race %>
<%= render "races/placeholder_banner" %>
<%= render "races/role_nav", race: @race %>

<section class="mx-auto max-w-[1240px] px-6 pb-16 sm:px-10">
  <h2 class="mb-2 text-2xl font-black uppercase tracking-tight">The crew map</h2>
  <p class="mb-5 max-w-2xl text-sm text-stone">
    Green points allow crew; the dashed line is the crew's driving route between them. Tap any point
    for parking, drop-bag and pacer info, and directions. Use the toggles below the map.
  </p>
  <%= render "races/map", race: @race, drive: true %>
  <% if @race.crew_route.present? %>
    <p class="mt-3 font-mono text-xs uppercase tracking-[0.12em] text-stone">
      Crew drive ≈ <%= @race.crew_route["distance_mi"] %> mi · <%= (@race.crew_route["duration_min"] / 60.0).round(1) %> h · Start → Dry Fork → Sally's → Jaws → Finish
    </p>
  <% end %>

  <h2 class="mb-4 mt-12 text-2xl font-black uppercase tracking-tight">Crew-accessible aid stations</h2>
  <%= render "races/aid_station_table", stations: @race.aid_stations.crew %>

  <p class="mt-6 text-sm text-stone">
    <%= @race.aid_stations.crew.size %> of <%= @race.aid_stations.size %> stations allow crew.
    Pacers may join where the table shows a pacer&nbsp;✓.
  </p>
</section>
