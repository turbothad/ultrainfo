<%= render "races/race_header", race: @race %>
<%= render "races/placeholder_banner" %>
<%= render "races/role_nav", race: @race %>

<section class="mx-auto max-w-[1240px] px-6 pb-16 sm:px-10">
  <div class="rounded-2xl border border-ink/10 bg-card p-6">
    <div class="font-mono text-[11px] uppercase tracking-[0.14em] text-stone">Live tracking</div>
    <% if @race.tracking_url.present? %>
      <%= link_to "Open live tracking →", @race.tracking_url, target: "_blank", rel: "noopener",
            class: "mt-2 inline-block text-xl font-extrabold text-ink no-underline hover:text-flame" %>
    <% else %>
      <p class="mt-2 text-stone">The official tracking link will appear here on race day.</p>
    <% end %>
  </div>

  <h2 class="mb-2 mt-12 text-2xl font-black uppercase tracking-tight">Best spots to watch</h2>
  <p class="mb-5 max-w-2xl text-sm text-stone">
    Crew-accessible aid stations are also the best places for spectators to catch a runner.
  </p>
  <%= render "races/map", race: @race %>

  <div class="mt-8 rounded-2xl border border-ink/10 bg-card p-6">
    <div class="font-mono text-[11px] uppercase tracking-[0.14em] text-stone">Finish</div>
    <p class="mt-2 text-stone"><%= @race.finish_venue.presence || "Finish-line details coming soon." %></p>
  </div>
</section>
