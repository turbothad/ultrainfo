<%= render "races/race_header", race: @race %>
<%= render "races/placeholder_banner" %>
<%= render "races/role_nav", race: @race %>

<section class="mx-auto max-w-[1240px] px-6 pb-16 sm:px-10">
  <div class="grid gap-6 lg:grid-cols-[1fr_1.4fr]">
    <div class="h-fit rounded-2xl border border-ink/10 bg-card p-6">
      <div class="font-mono text-[11px] uppercase tracking-[0.14em] text-stone">Registration</div>
      <div class="mt-2 text-2xl font-extrabold"><%= @race.registration_status.humanize %></div>
      <dl class="mt-4 flex flex-col gap-2 text-sm text-stone">
        <div class="flex justify-between"><dt>Lottery</dt><dd class="font-semibold text-ink"><%= @race.lottery? ? "Yes" : "No" %></dd></div>
        <% if @race.start_time.present? %><div class="flex justify-between"><dt>Start</dt><dd class="font-semibold text-ink"><%= @race.start_time %></dd></div><% end %>
        <% if @race.cutoff_hours %><div class="flex justify-between"><dt>Overall cutoff</dt><dd class="font-semibold text-ink"><%= @race.cutoff_hours.to_i %> h</dd></div><% end %>
      </dl>
      <% if @race.registration_url.present? %>
        <%= link_to "Where to register →", @race.registration_url, target: "_blank", rel: "noopener",
              class: "mt-5 inline-block rounded-full bg-ink px-5 py-3 text-sm font-bold text-paper no-underline hover:bg-flame" %>
        <p class="mt-3 font-mono text-[11px] text-stone-light">Opens on the official platform — we link, we don't sell.</p>
      <% end %>
    </div>

    <div>
      <% if @race.about.present? %>
        <p class="mb-4 text-base leading-relaxed text-stone"><%= @race.about %></p>
      <% end %>
      <%= render "races/elevation_profile", race: @race %>
    </div>
  </div>

  <h2 class="mb-4 mt-12 text-2xl font-black uppercase tracking-tight">Aid stations &amp; cutoffs</h2>
  <%= render "races/aid_station_table", stations: @race.aid_stations %>
</section>
